#!/bin/bash

wget -qO- 'https://download.docker.com/linux/debian/gpg' | gpg --dearmor > docker.gpg
sudo install -D -o root -g root -m 644 docker.gpg /etc/apt/keyrings/docker.gpg && rm docker.gpg
echo "deb [signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/debian trixie stable" |sudo tee /etc/apt/sources.list.d/docker.list > /dev/null

sudo apt update && sudo apt install docker-ce docker-compose-plugin -y