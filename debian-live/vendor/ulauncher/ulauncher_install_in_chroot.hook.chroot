#!/bin/bash

wget -qO- 'https://keyserver.ubuntu.com/pks/lookup?op=get&search=0x59EBDE772980C381CA13FA59FAF1020699503176' | gpg --dearmor > ulauncher.gpg
sudo install -D -o root -g root -m 644 ulauncher.gpg /etc/apt/keyrings/ulauncher.gpg && rm ulauncher.gpg
echo "deb [trusted=yes signed-by=/etc/apt/keyrings/ulauncher.gpg] http://ppa.launchpad.net/agornostal/ulauncher/ubuntu jammy main" |sudo tee /etc/apt/sources.list.d/ulauncher.list > /dev/null

sudo apt update && sudo apt install ulauncher -y