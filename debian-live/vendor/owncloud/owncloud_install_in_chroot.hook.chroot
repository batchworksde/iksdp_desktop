#!/bin/bash

wget -qO- https://download.owncloud.com/desktop/ownCloud/stable/latest/linux/Debian_13/Release.key | gpg --dearmor > packages.owncloud.gpg
sudo install -D -o root -g root -m 644 packages.owncloud.gpg /etc/apt/keyrings/packages.owncloud.gpg && rm packages.owncloud.gpg
echo "deb [signed-by=/etc/apt/keyrings/packages.owncloud.gpg] https://download.owncloud.com/desktop/ownCloud/stable/latest/linux/Debian_13/ /" |sudo tee /etc/apt/sources.list.d/owncloud.list > /dev/null

sudo apt update && sudo apt install owncloud-client -y